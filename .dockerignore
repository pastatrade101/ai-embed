# Keep the build context small and never bake secrets/artifacts into the image.
node_modules
.svelte-kit
build
package

# Secrets — injected at RUNTIME via docker-compose env_file, never copied in.
.env
.env.*
!.env.example

.git
.gitignore
.dockerignore
Dockerfile
docker-compose.yml

.DS_Store
Thumbs.db
.idea
.vscode
*.log
npm-debug.log*
vite.config.js.timestamp-*
