# .env — server-side only. Copy to .env and fill in. NEVER commit .env.

# ---- Public URL — REQUIRED in production (behind a domain / reverse proxy) ----
# The https origin browsers actually use to reach this app. If this is wrong,
# LOGIN and every other form submit FAIL (SvelteKit CSRF → 500/403), because the
# POST's Origin header won't match the server's expected origin.
# Leave BLANK for local dev (defaults to http://localhost:3000).
# Docker reads APP_ORIGIN; set both to your domain, e.g. https://ai.makutano.co.tz
APP_ORIGIN=
PUBLIC_APP_URL=

SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...          # service_role key — bypasses RLS, server only
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...                   # voyage-3 = 1024 dims
RESEND_API_KEY=re_...                   # lead notification emails
# Sender address — MUST be on a domain you've verified in Resend, or every send
# is rejected. e.g. Makutano <notifications@makutano.co.tz>. Defaults to that.
RESEND_FROM=
AUTH_SECRET=change-me-to-a-long-random-string   # signs login session cookies

# ---- Payments — Snippe (optional; blank disables online checkout) ----
# When blank, upgrades fall back to "contact us" manual activation.
SNIPPE_API_KEY=                                 # from your Snippe dashboard
SNIPPE_WEBHOOK_SECRET=                          # signs incoming webhooks (HMAC-SHA256)
# SNIPPE_BASE_URL=https://api.snippe.sh         # override only for sandbox
# The Snippe webhook URL is built from PUBLIC_APP_URL (set at the top of this file)
# as {PUBLIC_APP_URL}/api/payments/webhook/snippe. Snippe only accepts https, so in
# dev leave PUBLIC_APP_URL blank and configure the webhook in the Snippe dashboard.

# ---- Plan feature gating — optional ----
# Off by default: plans are descriptive only. Set to "on" to ENFORCE each plan's
# ticked features (embeddable widget, Sonnet model, email alerts, tours, summaries,
# bulk import, "Powered by Makutano" badge). Configure features per plan in the admin
# Plans console (or run db/009_plan_features.sql for sensible defaults) BEFORE enabling.
FEATURE_GATING=off

# ---- Deployment (Docker Compose) — optional ----
# APP_PORT=3000                                 # host port to publish (container always listens on 3000)
# (APP_ORIGIN / PUBLIC_APP_URL are set at the TOP of this file — required behind a domain.)

# ---- WhatsApp Cloud API (Meta) ----
# Reusable WhatsApp module + NotificationService (src/lib/server/whatsapp).
# From Meta ▸ WhatsApp ▸ API Setup. Start with the Meta TEST number, swap to your
# production business number later — same variables, no code change.
WHATSAPP_ACCESS_TOKEN=          # temporary or System User permanent token
WHATSAPP_PHONE_NUMBER_ID=       # "Phone number ID" (NOT the phone number itself)
WHATSAPP_BUSINESS_ACCOUNT_ID=   # WABA ID
WHATSAPP_VERIFY_TOKEN=          # any random string you invent; paste the SAME value into Meta's webhook config
WHATSAPP_APP_SECRET=            # Meta ▸ App ▸ Settings ▸ Basic ▸ App Secret — validates inbound webhook signatures
WHATSAPP_API_VERSION=v21.0      # Graph API version

# Protects the manual /api/notifications/whatsapp/* endpoints for server-to-server
# calls (header: x-internal-key). Operator/admin sessions are always allowed.
INTERNAL_API_KEY=

# ---- WhatsApp Embedded Signup (multi-tenant onboarding) ----
# Lets each tenant connect its OWN WhatsApp Business number from the dashboard.
# From your Meta App: App ID (public), App Secret (private), and the Embedded Signup
# "config id" (Facebook Login for Business configuration). Requires your app to have
# Advanced Access (App Review) for whatsapp_business_management + whatsapp_business_messaging.
META_APP_ID=
META_APP_SECRET=
META_CONFIG_ID=
META_GRAPH_VERSION=v23.0
# 32+ char secret used to encrypt tenant access tokens at rest (AES-256-GCM). REQUIRED
# for Embedded Signup. Generate: openssl rand -hex 32
WHATSAPP_ENC_KEY=
